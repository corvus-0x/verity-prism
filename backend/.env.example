DATABASE_URL=postgresql://catalyst:catalyst@localhost:5432/catalyst
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ANTHROPIC_API_KEY=sk-ant-your-key-here
UPLOAD_DIR=./uploads
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173"]
# Maximum upload size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800
# LangSmith observability (optional — tracing disabled if not set)
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=verity-prism
# OpenAI embeddings for PGVector hybrid search (optional — semantic search
# disabled if not set, keyword FTS search still works normally)
OPENAI_API_KEY=sk-...
